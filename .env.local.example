JWT_SECRET=change-me-in-production
DATABASE_PATH=./data/band-chat.db
AUTH_COOKIE_SECURE=auto

# File uploads
UPLOADS_PATH=data/uploads

# Push notifications (generate with: bunx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@lazzycal.com

# Giphy API key (get from https://developers.giphy.com/)
GIPHY_API_KEY=
